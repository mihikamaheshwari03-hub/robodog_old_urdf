#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import JointState
from std_msgs.msg import Float64MultiArray

# Must match controllers.yaml order exactly
JOINT_ORDER = [
    'j1',  'j12', 'j13',   # Left Front:  abduction, hip, knee
    'j2',  'j22', 'j23',   # Right Front: abduction, hip, knee
    'j3',  'j32', 'j33',   # Right Back:  abduction, hip, knee
    'j4',  'j42', 'j43',   # Left Back:   abduction, hip, knee
]

class GazeboBridgeNode(Node):
    def __init__(self):
        super().__init__('gazebo_bridge_node')
        self.sub = self.create_subscription(
            JointState, '/joint_targets', self.callback, 10)
        self.pub = self.create_publisher(
            Float64MultiArray,
            '/joint_group_position_controller/commands', 10)
        self.get_logger().info('Gazebo bridge started')

    def callback(self, msg: JointState):
        positions = dict(zip(msg.name, msg.position))
        out = Float64MultiArray()
        out.data = [positions.get(j, 0.0) for j in JOINT_ORDER]
        self.pub.publish(out)

def main(args=None):
    rclpy.init(args=args)
    rclpy.spin(GazeboBridgeNode())
    rclpy.shutdown()

if __name__ == '__main__':
    main()